import java.util.ArrayList;
import java.util.Scanner;
class longStringSearch{
	private ArrayList<String> stringList;
	longStringSearch(int a){
		stringList=new ArrayList<String>(a);
	}
	public void addString(String s) {
		stringList.add(s);
	}
	public void listPrint() {
		for(int i=0;i<stringList.size();i++) {
			System.out.println(stringList.get(i));
		}
	}
	public String longestString() {
		int l=0;
		for(int i=1;i<stringList.size();i++) {
			if(stringList.get(l).length()<stringList.get(i).length())
				l=i;
		}
		return stringList.get(l);
	} 
	public ArrayList getter() {
		return stringList;
	}
}
public class a01 {
	public static void main(String[] args) {
		Scanner s=new Scanner(System.in);
		System.out.println("몇개의 이름을 입력하실건가요? - ");
		int a=s.nextInt();
		longStringSearch ac=new longStringSearch(a);
		System.out.println(a + " 만큼의 ArrayList가 생성되었습니다.");
		for(int i=0;i<a;i++) {
			System.out.println((i+1) + "번째 이름 입력 - ");
			String b=s.next();
			ac.addString(b);
		}
		System.out.println("입력 완료");
		System.out.println("모든 이름 출력");
		ac.listPrint();
		System.out.print("가장 긴 이름 - ");
		System.out.println(ac.longestString());
	}
}
